{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noImplicitReturns": true
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts", "types/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
